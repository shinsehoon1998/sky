# 실행 모드
# HEADLESS=true     # 백그라운드 실행 (화면 표시 없이)
# DEBUG=true        # 디버그 모드 (상세 로그 + 스크린샷)
# SLOW_MO=300       # 디버깅용 슬로우 모션 (ms)

# 배치 크기 (KB 다중입력 한도에 맞춰 조정, 기본 4)
# BATCH_SIZE=4

# 데이터 파일 경로 (미지정 시 data/ 폴더에서 자동 검색)
# KB_DATA_FILE=./data/customers.xlsx

# 다운로드 폴더 (미지정 시 ~/Downloads/KB_consents)
# KB_DOWNLOAD_DIR=/원하는/경로

# 동의서출력 페이지 URL (알고 있는 경우 직접 지정)
# KB_CONSENT_URL=https://nsales.kbinsure.co.kr/...
